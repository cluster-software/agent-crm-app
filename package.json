{
  "name": "agent-crm-app",
  "version": "0.14.5-295b305",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run check:agent-instructions && npm run typecheck && npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "check:agent-instructions": "node scripts/check-agent-instructions.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "start": "npm run build && electron .",
    "rebuild:native": "electron-rebuild --only=better-sqlite3,node-pty",
    "dist": "npm run build && electron-builder --mac --arm64 --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.cluster.agent-crm",
    "productName": "Agent CRM",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cluster-software",
        "repo": "agent-crm-app",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*",
      "dist/electron/sdk-service.js",
      "**/node_modules/@agent-crm/**/*",
      "**/node_modules/@lix-js/**/*",
      "**/node_modules/libphonenumber-js/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/file-uri-to-path/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "52U6Q4B78J"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@agent-crm/sdk": "^0.7.5",
    "@tanstack/react-table": "^8.21.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.6.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.3"
  }
}
